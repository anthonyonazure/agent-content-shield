# Agent Content Shield - Environment Variables
# Copy to .env and customize as needed

# Ollama server URL (default: http://localhost:11434)
# OLLAMA_URL=http://localhost:11434

# Embedding model for semantic layer (default: nomic-embed-text)
# SHIELD_EMBED_MODEL=nomic-embed-text

# Classifier model for semantic layer (default: deepseek-r1:8b)
# SHIELD_CLASSIFIER_MODEL=deepseek-r1:8b

# Anthropic API key for NLI classifier (optional - falls back to Ollama)
# ANTHROPIC_API_KEY=sk-ant-...

# Hook type override (alternative to argv)
# SHIELD_HOOK=post-content
